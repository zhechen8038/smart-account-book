<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            style="@style/PageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="创建账号" />

        <TextView
            style="@style/PageSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="填写个人资料，开启轻松记账" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/surface_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText android:id="@+id/et_register_phone" style="@style/AppInput"
                    android:hint="@string/phone_hint" android:inputType="phone" android:maxLength="11" />
                <EditText android:id="@+id/et_register_password" style="@style/AppInput"
                    android:layout_marginTop="12dp" android:hint="@string/password_hint" android:inputType="textPassword" />
                <EditText android:id="@+id/et_confirm_password" style="@style/AppInput"
                    android:layout_marginTop="12dp" android:hint="@string/confirm_password_hint" android:inputType="textPassword" />
                <EditText android:id="@+id/et_register_name" style="@style/AppInput"
                    android:layout_marginTop="12dp" android:hint="@string/name_hint" android:inputType="textPersonName" />
                <EditText android:id="@+id/et_register_age" style="@style/AppInput"
                    android:layout_marginTop="12dp" android:hint="@string/age_hint" android:inputType="number" android:maxLength="3" />
                <EditText android:id="@+id/et_register_occupation" style="@style/AppInput"
                    android:layout_marginTop="12dp" android:hint="@string/occupation_hint" android:inputType="text" />

                <TextView
                    style="@style/SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="性别"
                    android:textSize="16sp" />

                <RadioGroup
                    android:id="@+id/rg_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <RadioButton android:id="@+id/rb_male" android:layout_width="wrap_content"
                        android:layout_height="48dp" android:text="@string/man" android:buttonTint="@color/purple_500" />
                    <RadioButton android:id="@+id/rb_female" android:layout_width="wrap_content"
                        android:layout_height="48dp" android:layout_marginStart="32dp"
                        android:text="@string/woman" android:buttonTint="@color/purple_500" />
                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_register"
                    style="@style/AppPrimaryButton"
                    android:layout_marginTop="18dp"
                    android:text="@string/register_title" />

                <TextView
                    android:id="@+id/tv_go_login"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/yes_count_hint"
                    android:textColor="@color/purple_700"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
